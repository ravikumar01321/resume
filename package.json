{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs'),path=require('path'); ['package-lock.json','yarn.lock'].forEach(f=>{const p=path.join(process.cwd(),f);try{fs.unlinkSync(p)}catch(e){}})\"",
    "build": "pnpm run typecheck && pnpm run build:resume && pnpm run build:api",
    "build:resume": "pnpm -C ./artifacts/resume run build",
    "build:api": "pnpm -C ./artifacts/api-server run build",
    "build:all": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.28.1",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  }
}
